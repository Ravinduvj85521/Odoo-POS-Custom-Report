<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_report_pos_order_search_inherit_template" model="ir.ui.view">
        <field name="name">report.pos.order.search.template.group</field>
        <field name="model">report.pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_report_pos_order_search"/>
        <field name="arch" type="xml">
            <xpath expr="//group" position="inside">
                <filter string="Main Product" name="group_by_product_tmpl" context="{'group_by': 'product_tmpl_id'}"/>
            </xpath>
        </field>
    </record>
</odoo>